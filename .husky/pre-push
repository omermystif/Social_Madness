BRANCH=$(git rev-parse --abbrev-ref HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B)

if echo "$COMMIT_MSG" | grep -q "^\[auto-sync\]" && [ "$BRANCH" = "develop" ]; then
  echo "⚡ Auto-sync push to develop — skipping build check"
  exit 0
fi

echo "🔨 Pre-push: validating build..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Fix errors before pushing."
  exit 1
fi
echo "✅ Build OK"
