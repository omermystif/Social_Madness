# Frontend
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE.apps.googleusercontent.com
VITE_STORAGE_MODE=server
VITE_API_URL=

# Cloud sync direction (optional). Default = auto:
#   localhost / 127.0.0.1   → push-only (localhost is master)
#   any other hostname      → pull-only (prod is read-only view)
# Override one direction explicitly: push-only | pull-only | bidirectional
# VITE_CLOUD_SYNC_DIRECTION=
# VITE_ENABLE_CLOUD_SYNC=true

# Backend
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE.apps.googleusercontent.com
PORT=3000
HOST=0.0.0.0
DB_PATH=server/taskmanager.db
BACKUP_DIR=server/backup
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_HOURS=24
POLL_INTERVAL_MS=5000
LOG_LEVEL=info
